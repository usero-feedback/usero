{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmit": true,
		"baseUrl": "..",
		"paths": {
			"@usero/sdk": ["./dist/vanilla.d.ts"],
			"@usero/sdk/react": ["./dist/react.d.ts"],
			"@usero/sdk/plugins/session-replay": ["./dist/plugins/session-replay.d.ts"],
			"@usero/sdk/replay": ["./dist/replay.d.ts"],
			"@usero/sdk/replay/react": ["./dist/replay/react.d.ts"]
		}
	},
	"include": ["consumer.test.ts"]
}
