{
  "name": "@usero/sdk",
  "version": "1.3.0",
  "description": "Usero SDK. Drop-in feedback widget (vanilla JS, React, or script tag) plus future plugins like session replay. Zero config, framework-free, tiny.",
  "license": "MIT",
  "author": "Will Smith <will@willsmithte.com>",
  "homepage": "https://usero.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/usero-feedback/usero.git"
  },
  "bugs": {
    "url": "https://github.com/usero-feedback/usero/issues"
  },
  "type": "module",
  "main": "./dist/vanilla.cjs",
  "module": "./dist/vanilla.js",
  "types": "./dist/vanilla.d.ts",
  "unpkg": "./dist/usero.iife.js",
  "jsdelivr": "./dist/usero.iife.js",
  "exports": {
    ".": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js",
      "require": "./dist/replay.cjs"
    },
    "./replay/react": {
      "types": "./dist/replay/react.d.ts",
      "import": "./dist/replay/react.js",
      "require": "./dist/replay/react.cjs"
    },
    "./headless": {
      "types": "./dist/headless.d.ts",
      "import": "./dist/headless.js",
      "require": "./dist/headless.cjs"
    },
    "./headless/react": {
      "types": "./dist/headless/react.d.ts",
      "import": "./dist/headless/react.js",
      "require": "./dist/headless/react.cjs"
    },
    "./plugins/session-replay": {
      "types": "./dist/plugins/session-replay.d.ts",
      "import": "./dist/plugins/session-replay.js",
      "require": "./dist/plugins/session-replay.cjs"
    },
    "./plugins/user-test": {
      "types": "./dist/plugins/user-test.d.ts",
      "import": "./dist/plugins/user-test.js",
      "require": "./dist/plugins/user-test.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node scripts/sync-wp-vendor.mjs && node scripts/verify-dist.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "feedback",
    "widget",
    "vanilla",
    "react",
    "embed",
    "user-feedback",
    "rating",
    "usero"
  ],
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "rrweb": "2.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
